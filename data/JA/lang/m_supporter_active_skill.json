  {
    "id": 160900001001000150,
    "value": "何をやったかで人間の値打ちは決まる"
  },
  {
    "id": 160900001001000250,
    "value": "各員は周囲に警戒を！"
  },
  {
    "id": 160900001001000450,
    "value": "-"
  },
  {
    "id": 160900001001000550,
    "value": "-"
  },
  {
    "id": 160900001001000650,
    "value": "-"
  },
  {
    "id": 160900001001000750,
    "value": "お止めなさい！争うのだけが人ではないでしょう!?"
  },
  {
    "id": 160900001013000150,
    "value": "おらおら！ボヤボヤしてっとやっちまうぞッ！"
  },
  {
    "id": 160900001022000150,
    "value": "-"
  },
  {
    "id": 160900001031000150,
    "value": "お願い…！　みんな生きて帰ってきて！"
  },
  {
    "id": 160900001055000360,
    "value": "-"
  },
  {
    "id": 160900001060000150,
    "value": "機関全速ッ！　逃がしてはならん！"
  },
  {
    "id": 160900001060000250,
    "value": "アタシゃ気が短いんだ！さっさと終わらせるよ！"
  },
  {
    "id": 160900001080000150,
    "value": "ア、アタシ…足手まといになんかならないわ！"
  },
  {
    "id": 160900001080000250,
    "value": "これ以上敵の良い様にさせるなッ！"
  },
  {
    "id": 160900001080000450,
    "value": "-"
  },
  {
    "id": 160900001080000550,
    "value": "無駄なのよ！見苦しいマネはよして欲しいわね！"
  },
  {
    "id": 160900001095000150,
    "value": "俺だって少しくらいはイイとこ見せないとな！"
  },
  {
    "id": 160900001095000250,
    "value": "-"
  },
  {
    "id": 160900001095000350,
    "value": "我が志によって、貴様は葬りさられるのだ！"
  },
  {
    "id": 160900001095000450,
    "value": "-"
  },
  {
    "id": 160900001095000560,
    "value": "-"
  },
  {
    "id": 160900001110000150,
    "value": "すまんが、みんなの命をくれ。"
  },
  {
    "id": 160900001110000250,
    "value": "-"
  },
  {
    "id": 160900001125000150,
    "value": "-"
  },
  {
    "id": 160900001125000250,
    "value": "地球圏を騒乱に巻き込むなど、もってのほかだ！"
  },
  {
    "id": 160900001125000350,
    "value": "-"
  },
  {
    "id": 160900001125000450,
    "value": "また、同じ過ちが繰り返されようとしているなら…！"
  },
  {
    "id": 160900001150000150,
    "value": "やっちゃいなよ、そんな偽物なんか！"
  },
  {
    "id": 160900001150000260,
    "value": "-"
  },
  {
    "id": 160900001200000150,
    "value": "もう私も黙って見てるなんてできない…！"
  },
  {
    "id": 160900001200000250,
    "value": "-"
  },
  {
    "id": 160900001200000350,
    "value": "フフフッ！"
  },
  {
    "id": 160900001210000150,
    "value": "戦争なんか、誰が望んでいるというのです…!?"
  },
  {
    "id": 160900001210000250,
    "value": "-"
  },
  {
    "id": 160900001210000350,
    "value": "実戦の厳しさというものを、教えてやる…！"
  },
  {
    "id": 160900001210000460,
    "value": "-"
  },
  {
    "id": 160900001230000150,
    "value": "未来を悲しい時代にしたくないから…！"
  },
  {
    "id": 160900001230000250,
    "value": "-"
  },
  {
    "id": 160900001230000350,
    "value": "私は、あの悲劇を繰り返したくはないのだ………！"
  },
  {
    "id": 160900001300000150,
    "value": "たとえ無茶でも、ここを乗り切らないと…！"
  },
  {
    "id": 160900001300000250,
    "value": "-"
  },
  {
    "id": 160900001300000350,
    "value": "-"
  },
  {
    "id": 160900001300000450,
    "value": "私も既に覚悟はできています…！"
  },
  {
    "id": 160900001300000550,
    "value": "やれやれ…退いてもらえると助かるんだがねぇ！"
  },
  {
    "id": 160900001300000650,
    "value": "はっはっはっはっは…！やったぁっ！"
  },
  {
    "id": 160900001300000760,
    "value": "-"
  },
  {
    "id": 160900001305000150,
    "value": "-"
  },
  {
    "id": 160900001305000250,
    "value": "与えられた仕事に見合う能力はあります！"
  },
  {
    "id": 160900001305000350,
    "value": "-"
  },
  {
    "id": 160900001330000150,
    "value": "-"
  },
  {
    "id": 160900001330000250,
    "value": "いい？………ここが正念場よ！"
  },
  {
    "id": 160900001370000150,
    "value": "世界の敵になる。それは悪行だけど…！"
  },
  {
    "id": 160900001370000250,
    "value": "-"
  },
  {
    "id": 160900001370000350,
    "value": "-"
  },
  {
    "id": 160900001370000450,
    "value": "私にも、何かやれる事はあるハズ………！"
  },
  {
    "id": 160900001400000150,
    "value": "何人たりとも、復讐の邪魔はさせん！"
  },
