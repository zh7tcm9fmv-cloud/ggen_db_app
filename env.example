# Copy this file to ".env" in the same folder as app.py (do NOT commit .env — it is gitignored).
#
# IMPORTANT — "online" / deployed server:
#   PowerShell on your PC only sets variables for that PC. Your hosting provider runs a
#   separate process: you must set the SAME names in the host's dashboard, OR upload
#   a ".env" file next to app.py on the server (after pip install -r requirements.txt).
#
# Examples: Railway / Render / Fly.io → Project → Environment / Variables
#           VPS → use .env file or systemd Environment= lines

# Required for secure sessions (password gate + watermark). Use a long random string in production.
FLASK_SECRET_KEY=your-long-random-secret-here

# Optional: HTTPS only session cookie (set when the site is served over HTTPS).
# FLASK_SESSION_SECURE=1

# Latest Release tab: password (leave unset = no lock, no watermark in API).
# Lineup is hidden only for gachas whose StartDatetime is still in the future (vs server time),
# until POST /api/latest_release/unlock succeeds for this session. Past/current releases stay public.
# Only /api/latest_release* uses this password; other tabs do not.
LATEST_RELEASE_PASSWORD=your-private-password

# Optional — testing: force password lock for one schedule even after its start time has passed.
# Must match the schedule Id in m_schedule.json for a gacha that actually appears in Latest Release
# (if no units/chars/supporters use that ScheduleId, there is no row to lock — use a banner id you see in-game).
# LATEST_RELEASE_TEST_LOCK_SCHEDULE_ID=2603209901
# Or lock by exact StartDatetime from m_schedule (epoch ms). Example 2026-03-20 12:00 JST:
# LATEST_RELEASE_TEST_LOCK_START_MS=1773975600000
#
# Troubleshooting: restart Flask after editing .env. Clear site cookies for this host if you already
# unlocked (session lr_unlocked). GET /api/latest_release/status → test_lock_schedule_id should match
# your Id, or .env was not loaded (wrong folder, or file named .env.txt).

# Latest Release list: first load shows ~3 calendar months (JST). API ?full=1 loads all.
