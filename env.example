# Copy to .env or set in the environment before running Flask.

# Required for secure sessions (password gate + watermark session). Change in production.
FLASK_SECRET_KEY=your-long-random-secret-here

# Optional: HTTPS only session cookie (set when behind HTTPS reverse proxy).
# FLASK_SESSION_SECURE=1

# Latest Release tab: password gate (leave unset to disable lock and watermarks).
# LATEST_RELEASE_PASSWORD=your-private-password
